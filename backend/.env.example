PORT=3001
JWT_SECRET=change_me_to_a_long_random_string
FRONTEND_URL=http://localhost:3000

# Velocity proxy (ping only, no RCON)
VELOCITY_HOST=127.0.0.1
VELOCITY_PORT=25577

# Lobby server
LOBBY_HOST=127.0.0.1
LOBBY_PORT=25566
LOBBY_RCON_PORT=25576
LOBBY_RCON_PASS=your_rcon_password

# Game server
GAME_HOST=127.0.0.1
GAME_PORT=25567
GAME_RCON_PORT=25577
GAME_RCON_PASS=your_rcon_password

# Paths to server directories on disk (for worlds listing)
LOBBY_SERVER_PATH=/opt/minecraft/lobby
GAME_SERVER_PATH=/opt/minecraft/game
